<Window x:Class="PCAndroidRooter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:PCAndroidRooter.ViewModels"
        xmlns:models="clr-namespace:PCAndroidRooter.Models"
        xmlns:converters="clr-namespace:PCAndroidRooter.Converters"
        Title="PC Android Rooter"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600"
        TextElement.FontFamily="{DynamicResource MaterialDesignBodyFont}"
        Background="{DynamicResource MaterialDesignPaper}"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        Loaded="OnLoaded"
        Closing="OnClosing">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:StatusToColorConverter x:Key="StatusToColor" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════ HEADER ═══════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="28"
                               Foreground="White" VerticalAlignment="Center" />
                    <TextBlock Text="PC Android Rooter" FontSize="22" FontWeight="SemiBold"
                               Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Android" Width="18" Height="18"
                        Foreground="{Binding ConnectionStatus, Converter={StaticResource StatusToColor}}" />
                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="13"
                               Foreground="White" Margin="6,0,0,0" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding ConnectionStatus, Converter={StaticResource StatusToColor}}"
                             Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ShieldCheck" Width="18" Height="18"
                        Foreground="{Binding IsDeviceRooted, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="Root detectado" FontSize="13" Foreground="#66BB6A"
                               Margin="6,0,0,0"
                               Visibility="{Binding IsDeviceRooted, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
        <Grid Grid.Row="1" Margin="16,12,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ────────── LEFT PANEL: Device + Info ────────── -->
            <Border Grid.Column="0" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="16" Margin="0,0,8,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Device Selector -->
                        <TextBlock Text="DISPOSITIVO" Style="{StaticResource SectionTitle}" />

                        <ComboBox ItemsSource="{Binding DeviceList}"
                                  SelectedItem="{Binding SelectedSerial, UpdateSourceTrigger=PropertyChanged}"
                                  materialDesign:HintAssist.Hint="Seleccionar dispositivo"
                                  Style="{StaticResource MaterialDesignComboBox}"
                                  Margin="0,0,0,12"
                                  Visibility="{Binding IsDeviceConnected, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="Conecta un dispositivo Android por USB"
                                   FontSize="13" Opacity="0.6" TextWrapping="Wrap"
                                   Visibility="{Binding IsDeviceConnected, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                   Margin="0,8,0,12" />

                        <!-- Quick Actions -->
                        <WrapPanel Margin="0,0,0,12">
                            <Button Command="{Binding RefreshDeviceCommand}" ToolTip="Actualizar información"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="0,0,4,4">
                                <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding RebootDeviceCommand}" ToolTip="Reiniciar dispositivo"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="0,0,4,4">
                                <materialDesign:PackIcon Kind="Restart" Width="18" Height="18" />
                            </Button>
                            <Button Command="{Binding RebootBootloaderCommand}" ToolTip="Reiniciar a bootloader"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="0,0,4,4">
                                <materialDesign:PackIcon Kind="DeveloperBoard" Width="18" Height="18" />
                            </Button>
                        </WrapPanel>

                        <!-- Device Info Section -->
                        <TextBlock Text="INFORMACIÓN DEL DISPOSITIVO" Style="{StaticResource SectionTitle}"
                                   Visibility="{Binding IsDeviceConnected, Converter={StaticResource BoolToVis}}" />

                        <Grid Visibility="{Binding IsDeviceConnected, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Modelo:" Style="{StaticResource InfoLabel}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeviceModel}" Style="{StaticResource InfoValue}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fabricante:" Style="{StaticResource InfoLabel}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DeviceManufacturer}" Style="{StaticResource InfoValue}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Android:" Style="{StaticResource InfoLabel}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeviceAndroidVersion}" Style="{StaticResource InfoValue}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Build:" Style="{StaticResource InfoLabel}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DeviceBuild}" Style="{StaticResource InfoValue}" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Batería:" Style="{StaticResource InfoLabel}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DeviceBattery}" Style="{StaticResource InfoValue}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="ABI:" Style="{StaticResource InfoLabel}" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DeviceAbi}" Style="{StaticResource InfoValue}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Seguridad:" Style="{StaticResource InfoLabel}" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding DeviceSecurityPatch}" Style="{StaticResource InfoValue}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="RAM:" Style="{StaticResource InfoLabel}" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding DeviceRam}" Style="{StaticResource InfoValue}" />

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Root:" Style="{StaticResource InfoLabel}" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="✓ Con root" Foreground="#66BB6A" FontWeight="Bold"
                                           Visibility="{Binding IsDeviceRooted, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="✗ Sin root" Foreground="#EF5350" FontWeight="Bold"
                                           Visibility="{Binding IsDeviceRooted, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                            </StackPanel>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Bootloader:" Style="{StaticResource InfoLabel}" />
                            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Desbloqueado" Foreground="#66BB6A" FontWeight="Bold"
                                           Visibility="{Binding BootloaderUnlocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="Bloqueado" Foreground="#FFA726" FontWeight="Bold"
                                           Visibility="{Binding BootloaderUnlocked, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                            </StackPanel>
                        </Grid>

                        <!-- ADB Progress -->
                        <ProgressBar IsIndeterminate="True"
                                     Visibility="{Binding IsAdbReady, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                     Margin="0,8,0,0" />

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ────────── RIGHT PANEL: Root Methods ────────── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,0,0,0">

                    <TextBlock Text="MÉTODOS DE ROOT" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Selecciona un método para rootear tu dispositivo"
                               FontSize="13" Opacity="0.5" Margin="0,0,0,16" />

                    <ItemsControl ItemsSource="{Binding RootMethods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:RootMethod}">
                                <Border CornerRadius="8" BorderThickness="1"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        Background="{DynamicResource MaterialDesignCardBackground}"
                                        Padding="16" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <Border Grid.Column="0" Width="42" Height="42"
                                                    CornerRadius="21"
                                                    Background="{DynamicResource PrimaryHueMidBrush}"
                                                    VerticalAlignment="Center" Margin="0,0,14,0">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="20"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name + Desc -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Status -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{Binding StatusColor}"
                                                         HorizontalAlignment="Center"
                                                         Margin="0,0,0,4" />
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11" Opacity="0.7"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>

                                        <Button Command="{Binding DataContext.ExecuteRootMethodCommand,
                                            RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                            CommandParameter="{Binding}"
                                            Content="EJECUTAR"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Background="{DynamicResource PrimaryHueMidBrush}"
                                            Foreground="White"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Right"
                                            Visibility="{Binding DataContext.IsDeviceConnected,
                                                RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}},
                                                Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════ STATUS BAR ═══════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource MaterialDesignCardBackground}"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource MaterialDesignDivider}"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon Grid.Column="0" Kind="Information" Width="16" Height="16"
                    Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="2" Command="{Binding ClearLogCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}" Padding="8,2"
                        ToolTip="Limpiar log" FontSize="11">
                    LIMPIAR LOG
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════ LOG CONSOLE ═══════════════════ -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                Background="#1E1E1E" Margin="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#252526" Padding="12,6">
                    <Grid>
                        <TextBlock Text="CONSOLA" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#888" VerticalAlignment="Center" />
                        <ProgressBar IsIndeterminate="True" Height="3"
                                     Visibility="{Binding IsRooting, Converter={StaticResource BoolToVis}}"
                                     VerticalAlignment="Bottom" Margin="0,6,0,-8" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="LogScrollViewer">
                     <TextBox Text="{Binding LogText, Mode=OneWay}"
                              FontFamily="Cascadia Code, Consolas, Courier New"
                              FontSize="13"
                              Background="Transparent"
                              Foreground="#F0F0F0"
                              BorderThickness="0"
                              IsReadOnly="True"
                              Padding="12,8"
                              TextWrapping="Wrap"
                              VerticalScrollBarVisibility="Hidden"
                                      materialDesign:TextFieldAssist.HasClearButton="False" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════ ROOTING OVERLAY ═══════════════════ -->
        <Border Grid.RowSpan="4"
                Background="#AA000000"
                Visibility="{Binding IsRooting, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="ShieldSync" Width="64" Height="64"
                    Foreground="{DynamicResource PrimaryHueMidBrush}">
                    <materialDesign:PackIcon.RenderTransform>
                        <RotateTransform x:Name="SpinTransform" Angle="0" />
                    </materialDesign:PackIcon.RenderTransform>
                </materialDesign:PackIcon>
                <TextBlock Text="EJECUTANDO ROOT..." FontSize="24" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,16,0,8" />
                <TextBlock Text="No desconectes el dispositivo ni cierres la aplicación"
                           FontSize="14" Foreground="#CCC" HorizontalAlignment="Center" Margin="0,0,0,24" />
                <Button Command="{Binding CancelRootCommand}"
                        Content="CANCELAR"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Background="#EF5350" Foreground="White"
                        HorizontalAlignment="Center" Padding="24,8" />
            </StackPanel>
        </Border>

    </Grid>
</Window>
